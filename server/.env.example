# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/rent-flatmate-finder

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Groq LLM (get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Email — Nodemailer (Mailtrap recommended for testing, Gmail app passwords also work)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your_mailtrap_smtp_user
EMAIL_PASS=your_mailtrap_smtp_password
EMAIL_FROM="Rent & Flatmate Finder <no-reply@rentfinder.com>"

# Compatibility engine
HIGH_COMPATIBILITY_THRESHOLD=80
